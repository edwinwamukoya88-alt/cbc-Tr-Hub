rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.role == 'super_admin';
    }
    match /subscriptions/{subId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    match /ai_usage/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    match /curriculum/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == 'super_admin';
    }
    match /resources/{resourceId} {
      allow read: if resource.data.status == 'published' || (request.auth != null && resource.data.authorId == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.authorId == request.auth.uid || request.auth.token.role == 'super_admin');
      allow delete: if request.auth != null && request.auth.token.role == 'super_admin';
    }
    match /quality_reviews/{reviewId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /report_cards/{reportCardId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    match /generated_content/{contentId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /blog_posts/{postId} {
      allow read: if resource.data.status == 'published' || (request.auth != null && request.auth.token.role == 'super_admin');
      allow write: if request.auth != null && request.auth.token.role == 'super_admin';
    }
    match /schools/{schoolId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == 'super_admin';
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
